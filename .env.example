# AstraCart Enterprise Platform environment
ENVIRONMENT=local
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-me-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

POSTGRES_USER=astracart
POSTGRES_PASSWORD=astracart_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=astracart

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

USER_DATABASE_URL=postgresql+psycopg://astracart:astracart_password@postgres:5432/users_db
PRODUCT_DATABASE_URL=postgresql+psycopg://astracart:astracart_password@postgres:5432/products_db
CART_DATABASE_URL=postgresql+psycopg://astracart:astracart_password@postgres:5432/carts_db
ORDER_DATABASE_URL=postgresql+psycopg://astracart:astracart_password@postgres:5432/orders_db
PAYMENT_DATABASE_URL=postgresql+psycopg://astracart:astracart_password@postgres:5432/payments_db
NOTIFICATION_DATABASE_URL=postgresql+psycopg://astracart:astracart_password@postgres:5432/notifications_db

USER_SERVICE_URL=http://user-service:8000
PRODUCT_SERVICE_URL=http://product-service:8000
CART_SERVICE_URL=http://cart-service:8000
ORDER_SERVICE_URL=http://order-service:8000
PAYMENT_SERVICE_URL=http://payment-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
